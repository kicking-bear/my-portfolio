---
import { sanityClient } from '../sanity'

const caseStudies = await sanityClient.fetch(`
  *[_type == "caseStudy"] | order(featured desc) {
    title,
    slug,
    tagline,
    tags,
    role,
    timeline,
    featured,
    isProtected
  }
`)
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Your Name — UX Designer</title>
  </head>
  <body>

    <nav>
      <span>Your Name</span>
      <div>
        <a href="/">Work</a>
        <a href="/about">About</a>
        <a href="/writing">Writing</a>
      </div>
    </nav>

    <main>
      <section>
        <h1>Designing systems people trust.</h1>
        <p>UX Designer — Product · Research · Systems</p>
      </section>

      <section>
        <h2>Selected work</h2>
        <div>
          {caseStudies.map((study: any) => (
            <a href={`/work/${study.slug.current}`}>
              <div>
                <span>{study.featured ? 'Featured' : ''}</span>
                {study.tags?.map((tag: string) => (
                  <span>{tag}</span>
                ))}
              </div>
              <h3>{study.title}</h3>
              <p>{study.tagline}</p>
              <p>{study.role} — {study.timeline}</p>
            </a>
          ))}
        </div>
      </section>
    </main>

  </body>
</html>